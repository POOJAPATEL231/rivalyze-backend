# LLM lanes. Multiple keys per provider are supported for automatic rotation on
# 429 / out-of-quota: comma-separate them (KEY=k1,k2,k3) and/or use numbered
# vars (GROQ_API_KEY_2=...). The router tries the next key for the SAME provider
# before failing over to a different one.
# Lane models are env-overridable too: CEREBRAS_MODEL, GROQ_EXTRACT_MODEL,
# GROQ_REASON_MODEL, GEMINI_MODEL, OPENROUTER_EXTRACT_MODEL, OPENROUTER_REASON_MODEL.
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
DATABASE_URL=postgresql://rivalyze:PW@SERVER.postgres.database.azure.com:5432/rivalyze?sslmode=require
REDIS_URL=rediss://:KEY@NAME.redis.cache.windows.net:6380/0
# Leave blank ONLY for local/offline runs (MOCK_MODE=1 or AUTH_DISABLED=1).
# A non-mock deploy MUST set a strong random token, or the app refuses to serve (fail-closed).
BEARER_TOKEN=
FRONTEND_ORIGIN=http://localhost:5173
# user auth (JWT) — generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# rate limiting on /login /signup /refresh (storage: REDIS_URL if set, else memory)
RATE_LIMIT_ENABLED=1
# per-competitor intel cache: when 1, re-analyzing only calls the agents for NEWLY
# added rivals (cached rivals are reused for COMPETITOR_INTEL_TTL seconds). Fewer
# LLM calls -> fewer 429s. Needs REDIS_URL or DATABASE_URL to actually cache.
COMPETITOR_INTEL_CACHE=0
COMPETITOR_INTEL_TTL=86400
# richer search: when 1, agents fetch more results/query (6), Tavily 'advanced' depth,
# and a bigger corpus (12k) -> deeper reports but MORE input tokens. Only enable with
# quota headroom. Each value is independently overridable.
RICH_SEARCH=0
# SEARCH_MAX_RESULTS=6
# SEARCH_DEPTH=advanced
# CORPUS_CAP=12000
MOCK_MODE=0
DEMO_RESERVE=0
AUTH_DISABLED=0
# inactive fallbacks:
SUPABASE_DATABASE_URL=
UPSTASH_URL=
UPSTASH_TOKEN=
BEDROCK_API_KEY=
