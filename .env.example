# === Secret source ===
# In a deployed run, set ONLY AZURE_KEY_VAULT_URL and leave the secrets below
# BLANK — they are pulled from the vault at startup (see docs/azure_key_vault.md).
# Locally you can skip the vault and just fill the values below; a value set here
# always wins over the vault. AZURE_KEY_VAULT_STRICT=1 makes a vault load failure
# fatal (recommended in prod).
AZURE_KEY_VAULT_URL=
AZURE_KEY_VAULT_STRICT=0

# LLM lanes / search (leave blank in prod → sourced from Key Vault)
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
# Persistence + auth (leave blank in prod → sourced from Key Vault)
DATABASE_URL=
REDIS_URL=
BEARER_TOKEN=
JWT_SECRET=
FRONTEND_ORIGIN=http://localhost:5173
MOCK_MODE=0
DEMO_RESERVE=0
# inactive fallbacks:
SUPABASE_DATABASE_URL=
UPSTASH_URL=
UPSTASH_TOKEN=
BEDROCK_API_KEY=
